"  TABLINE (buffer tabs without plugins)
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function! Tabline()
  let l:s = ''
  for i in range(1, bufnr('$'))
    if !buflisted(i) | continue | endif
    let l:name    = fnamemodify(bufname(i), ':t')
    let l:name    = empty(l:name) ? '[No Name]' : l:name
    let l:current = (i == bufnr('%'))
    let l:mod     = getbufvar(i, '&modified') ? ' ●' : ''
    let l:s .= l:current ? '%#TabLineSel#' : '%#TabLine#'
    let l:s .= ' ' . i . '  ' . l:name . l:mod . ' '
  endfor
  let l:s .= '%#TabLineFill#'
  return l:s
endfunction
set tabline=%!Tabline()

