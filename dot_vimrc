" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"  AUTOCOMMANDS
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
augroup GeneralAutocmds
  autocmd!
  " Return to last edit position when reopening a file
  autocmd BufReadPost *
        \ if line("'\"") > 1 && line("'\"") <= line("$") && &ft !~# 'commit'
        \ |   execute "normal! g'\""
        \ | endif

  " Trim trailing whitespace on save (except markdown/txt)
  autocmd BufWritePre *
        \ if &ft !~# 'markdown\|text'
        \ |   let l:save = winsaveview()
        \ |   silent! keeppatterns %s/\s\+$//e
        \ |   call winrestview(l:save)
        \ | endif

  " Auto-reload vimrc on save
"  autocmd BufWritePost $MYVIMRC source $MYVIMRC | echom "vimrc reloaded"

  " Resize splits when Vim is resized
  autocmd VimResized * tabdo wincmd =

  " Highlight yanked text briefly (Vim 9+ / neovim)
  if exists('##TextYankPost')
    autocmd TextYankPost * silent! call timer_start(0, {->
          \ execute("let &hlsearch=&hlsearch") })
  endif

  " Set cursorline only in active window
  autocmd WinEnter * setlocal cursorline
  autocmd WinLeave * setlocal nocursorline

  " Open quickfix window automatically after grep
  autocmd QuickFixCmdPost [^l]* cwindow
  autocmd QuickFixCmdPost    l* lwindow
augroup END

