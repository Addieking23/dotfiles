"  AUTO-PAIRS (bracket / quote closing — no plugins)
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
inoremap ( ()<Left>
inoremap [ []<Left>
inoremap { {}<Left>
inoremap {<CR> {<CR>}<Esc>O
inoremap (<CR> (<CR>)<Esc>O
inoremap [<CR> [<CR>]<Esc>O
inoremap " ""<Left>
inoremap ' ''<Left>
inoremap ` ``<Left>

" Skip over closing bracket if already there
inoremap <expr> ) strpart(getline('.'), col('.')-1, 1) ==# ')' ? "\<Right>" : ')'
inoremap <expr> ] strpart(getline('.'), col('.')-1, 1) ==# ']' ? "\<Right>" : ']'
inoremap <expr> } strpart(getline('.'), col('.')-1, 1) ==# '}' ? "\<Right>" : '}'

