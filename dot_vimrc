" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"  CORE - Must be first
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set nocompatible                " Disable Vi compatibility — unlock full Vim
filetype plugin indent on       " Enable filetype detection + per-type settings
syntax enable                   " Syntax highlighting

" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"  APPEARANCE
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set number                      " Absolute line number on current line
set relativenumber              " Relative numbers for fast j/k navigation
set cursorline                  " Highlight the current line
set signcolumn=yes              " Always show sign column (no layout shift)
set showmatch                   " Briefly jump to matching bracket
set matchtime=2                 " How long (tenths of sec) to show the match
set laststatus=2                " Always show the status line
set showtabline=2               " Always show the tab bar
set showcmd                     " Show partial commands in the bottom right
set title                       " Set terminal title to filename
set termguicolors               " 24-bit RGB colors (modern terminals)
set background=dark

" ── Colorscheme (best built-ins; uncomment the one you like) ──
colorscheme modus_vivendi_deuteranopia

" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"  EDITOR BEHAVIOUR
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set hidden                      " Switch buffers without saving
set confirm                     " Ask instead of failing on unsaved changes
set autoread                    " Reload files changed outside Vim
set updatetime=300              " Faster CursorHold events (ms)
set timeoutlen=500              " Key sequence timeout (ms)
set ttimeoutlen=10              " Key code timeout (faster Escape)
set history=10000               " Command history size
set undofile                    " Persistent undo across sessions
set undodir=~/.vim/undo//       " Undo files location (// = unique names)
set undolevels=10000            " Max undo steps
set backupdir=~/.vim/backup//   " Backups out of the way
set directory=~/.vim/swap//     " Swapfiles out of the way
set backup                      " Keep backup files
set swapfile                    " Keep swap files (crash recovery)

" Create dirs if they don't exist
if !isdirectory(expand('~/.vim/undo'))
  silent! call mkdir(expand('~/.vim/undo'), 'p', 0700)
endif
if !isdirectory(expand('~/.vim/backup'))
  silent! call mkdir(expand('~/.vim/backup'), 'p', 0700)
endif
if !isdirectory(expand('~/.vim/swap'))
  silent! call mkdir(expand('~/.vim/swap'), 'p', 0700)
endif

" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"  INDENTATION & WHITESPACE
" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set expandtab                   " Tabs → spaces
set tabstop=4                   " Visual width of a tab character
set softtabstop=4               " Spaces inserted on Tab key
set shiftwidth=4                " Spaces for >> / << indent
set shiftround                  " Round indent to multiple of shiftwidth
set autoindent                  " Copy indent from previous line
set smartindent                 " Context-aware auto-indent
set wrap                        " Wrap long lines visually
set linebreak                   " Wrap at word boundaries, not mid-word
set breakindent                 " Preserve indent on wrapped lines
set showbreak=↳\                " Visual cue for wrapped lines
set list                        " Show invisible characters
set listchars=tab:→\ ,trail:·,nbsp:␣,extends:›,precedes:‹

" Per-filetype overrides

" ===================== PYTHON SPECIFIC =====================
augroup python_settings
    autocmd!
    autocmd FileType python
        \ setlocal tabstop=4 softtabstop=4 shiftwidth=4 textwidth=88 |
        \ setlocal colorcolumn=88 |
        \ setlocal commentstring=#\ %s |
        \ highlight ColorColumn ctermbg=235 guibg=#2c2c2c
augroup END

" ===================== C / C++ SPECIFIC =====================
augroup c_settings
    autocmd!
    autocmd FileType c,cpp
        \ setlocal tabstop=4 softtabstop=4 shiftwidth=4 textwidth=100 |
        \ setlocal colorcolumn=100 |
        \ setlocal cindent |
        \ setlocal commentstring=//\ %s
augroup END

