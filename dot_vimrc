" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set foldmethod=indent           " Fold by indent (works everywhere)
set foldlevelstart=99           " Open all folds by default
set foldnestmax=5               " Limit fold depth
set foldcolumn=1                " Show fold indicators in gutter

" Prettier fold text
function! NeatFoldText()
  let l:line   = getline(v:foldstart)
  let l:indent = matchstr(l:line, '^\s*')
  let l:clean  = substitute(l:line, '^\s*', '', '')
  let l:lines  = v:foldend - v:foldstart + 1
  return l:indent . '▶ ' . l:clean . ' ··· ' . l:lines . ' lines'
endfunction
set foldtext=NeatFoldText()

