{
  "relative_line_numbers": "enabled",
  "git_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "vim_mode": true,
  "edit_predictions": {
    "mode": "subtle"
  },
  "show_edit_predictions": false,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Modus Vivendi Deuteranopia"
  },
  "languages": {
    "Python": {
      "language_servers": [
        "ty",
        "ruff"
      ]
    }
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": null
    }
  }
}
